# =================================================
# Script2API — .env.example
# Copie para .env e preencha com os valores reais.
# NUNCA commite o .env no repositório.
# =================================================

# ── Core ─────────────────────────────────────────
APP_ENV=development
APP_PORT=8000

# URL públicas (usados em success/cancel do Stripe e CORS)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ── CORS ─────────────────────────────────────────
# Lista separada por vírgula de origens permitidas
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

# ── JWT ──────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=TROQUE_POR_UMA_CHAVE_ALEATORIA_DE_64_CHARS_MINIMO
JWT_EXPIRE_HOURS=24

# ── Banco de Dados ────────────────────────────────
# Supabase: Ajustes > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxx.supabase.co:5432/postgres

# ── Stripe ───────────────────────────────────────
# Chaves de TESTE para desenvolvimento
STRIPE_API_KEY=sk_test_SUA_CHAVE_AQUI
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX
# Price ID do produto "Pro" no painel Stripe
STRIPE_PRO_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXXXXXX

# ── Limites e Sandbox ─────────────────────────────
FREE_TIER_MONTHLY_LIMIT=5
SANDBOX_TIMEOUT=5.0
SANDBOX_MAX_SOURCE_KB=64
