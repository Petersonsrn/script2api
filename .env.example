# Application
APP_NAME=Script2API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-to-a-random-secret

# CORS - origins separados por vírgula
CORS_ORIGINS=http://localhost:3000,http://localhost:5500

# Free tier limit (executions per user per month)
FREE_TIER_LIMIT=10

# Optional: OpenAI key for AI-enhanced endpoint naming
OPENAI_API_KEY=
